# checkov:skip=CKV_DOCKER_2:HEALTHCHECK not applicable for Lambda/AgentCore managed containers
# checkov:skip=CKV_DOCKER_3:Non-root user enforced by Lambda runtime
# Use AWS Lambda Python base image
FROM public.ecr.aws/lambda/python:3.11

# Install system dependencies for textract-textractor
# poppler-utils is required for PDF processing (available in default AL2 repos).
# tesseract is NOT needed — this Lambda uses Amazon Textract (cloud OCR), not local tesseract.
RUN yum install -y \
    poppler-utils \
    && yum clean all

# Copy shared utilities from parent context
COPY gateway/utilities/ ${LAMBDA_TASK_ROOT}/

# Copy tool code
COPY gateway/tools/textractor_tool/ ${LAMBDA_TASK_ROOT}/

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Set the CMD to your handler
CMD ["lambda_function.lambda_handler"]
